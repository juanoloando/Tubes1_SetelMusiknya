function moveForPaint()
{ Memilih arah gerak yang memberikan nilai okupansi wilayah tertinggi (greedy paint-first movement) }
{ Deklarasi }
dir, bestDir : Direction
score, bestScore : integer
nextLoc : MapLocation
{ Algoritma }
bestScore <- -∞
bestDir <- null
for setiap dir di DIRS do
    if rc.canMove(dir) then
        nextLoc <- rc.getLocation() + dir
        score <- calcMovePaintScore(nextLoc)
        \{ Fungsi Obyektif: skor = nilai cat + bonus reruntuhan - penalti jejak \}
        \{ Greedy Choice: pilih arah dengan skor TERTINGGI saat ini \}
        if score > bestScore then
            bestScore <- score
            bestDir <- dir
        end if
    end if
end for
if bestDir != null then
    rc.move(bestDir)
    SharedMemory.recordTrail(rc.getLocation())
end if
